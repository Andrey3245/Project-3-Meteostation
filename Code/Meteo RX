// Функция для радио
void nrffunction() { 
    radio.begin();
    radio.setAutoAck(true);           // Включить подтверждение
    radio.setRetries(3, 10);          // 3*250мкс, 10 попыток
    radio.enableAckPayload();
    radio.setChannel(106);            // Канал 106 (0x6a = 106)
    radio.setPALevel(RF24_PA_MAX);    // Максимальная мощность
    radio.setDataRate(RF24_1MBPS);    // Скорость 1 Мбит/с
    radio.setPayloadSize(sizeof(SensorData)); // Размер пакета
    radio.powerUp();
    radio.openReadingPipe(1, address[0]);
    radio.startListening();               // Режим приёма
}

// Функция проверки данных от датчика с улицы
void checkWirelessData() { 
    if (radio.available()) {
        radio.read(&rxData, sizeof(rxData));
        lastReceiveTime = millis();
        dataIsFresh = true;
    }
}

// Функция сброса данных от датчика с улицы
void resetWirelessData() { /
    rxData.sensorOK = false;
    rxData.temperatureout = -999.0;
    rxData.humidityout = -999.0;
    dataIsFresh = false;
}

// Управление ШИМ светодиодов 
void setColor(int r, int g, int b) { 
  analogWrite(red, r);
  analogWrite(green, g);
  analogWrite(blue, b);
}

// Ниже функции плавной смены цвета RGB светодиодов в зависимости от времени

void night () {
  fotoresistor2 = 0.99;
  r = 2; g = 0; b = 2;
  } 
  
void morning () { float progress = (currentHour - 8 + (float)currentMinute / 60.0) / 3.0;
      if (progress < 0.5) {
      float subProgress = progress * 2.0; 
      r = 255;                            
      g = 80 + subProgress * 100;        
      b = 0 + subProgress * 50;            
  }
      else {  
      float subProgress = (progress - 0.5) * 2.0; 
      r = 255 - subProgress * 180;        
      g = 180 - subProgress * 50;        
      b = 50 + subProgress * 205;         
    }
}
void dayy () {  r = 75;
   g = 130;  
   b = 255; 
   }
   
   void zakat() { 
    float progress = ((currentHour - 17) * 60 + currentMinute)/180.0;
      if (progress < 0.33) {
      float subProgress = progress * 3.0; 
      r = 75 + subProgress * 180;   
      g = 130 - subProgress * 30;   
      b = 255 - subProgress * 205;  
  }
      else if (progress < 0.66) {  
       float subProgress = (progress - 0.33) * 3.0; 
        r = 255;                      
        g = 100 - subProgress * 30;   
        b = 50 + subProgress * 100;    
  }
      else {
        float subProgress = (progress - 0.66) * 3.0; // 0.0 → 1.0
        r = 255;                     
        g = 70 - subProgress * 70;   
        b = 150 - subProgress * 148;   
        }
   }
void zakatt() {
   float progress = ((currentHour - 20) * 60 + currentMinute)/120.0;
      if (progress < 0.5) {
      float subProgress = progress * 2.0;    
       r = 255 - subProgress * 150;  
       g = 0;    
       b = 0;   
      }
      else {
      float subProgress = (progress - 0.5) * 2.0;
      r = 105 - subProgress * 100;    
      g = 0;      
      b = 0;       
    }
}
double davlenie() { // Функция чтения и усреднения давления для прогноза дождя
  double sumPres1 = 0;
  for (byte i = 0; i < 10; i++) {
    double pres1 = bmp.readPressure();
    sumPres1 += pres1;
   
  }
  return (sumPres1 / 10.0);
}
