    fotoresistor2 = constrain(fotoresistor2,  0.05, 0.99);

    checkWirelessData();     // Проверка данных от беспроводного датчика
    if (lastReceiveTime > 0 && millis() - lastReceiveTime > 3600000) {    // Проверка потери связи (если данных нет более 60 минут)
