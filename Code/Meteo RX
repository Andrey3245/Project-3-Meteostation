template <typename T> // Медианный фильтр
class Median3 {
public:
    T filter(T val) {
        if (++i >= 3) i = 0;
        buf[i] = val;
        return getMedian(buf[0], buf[1], buf[2]);
    }
    void init(T val) {
        buf[0] = buf[1] = buf[2] = val;
    }
    static inline T getMedian(T a, T b, T c) {
        return (a < b) ? ((b < c) ? b : ((c < a) ? a : c)) : ((a < c) ? a : ((c < b) ? b : c));
    }

private:
    T buf[3] = {};
    uint8_t i = 0;
};

Median3<int> med; // Экспоненциальный фильтр

class ExpFilter {
private:
    float filtered = 0;
    const float alpha = 0.1;  // Коэффициент сглаживания
public:
    float filter(float newValue) {
        filtered = alpha * newValue + (1 - alpha) * filtered;
        return filtered;
    }
    void init(float val) { filtered = val; }
};
ExpFilter expF;

